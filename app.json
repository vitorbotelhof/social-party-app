{
  "expo": {
    "name": "Entre Nós",
    "slug": "entre-nos",
    "version": "1.0.0",
    "scheme": "entrenos",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0D0D"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.entrenos.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#0D0D0D"
      },
      "package": "com.entrenos.app"
    },
    "web": {
      "favicon": "./assets/logo.png"
    },
    "locales": {
      "pt-BR": "./locales/pt-BR.json"
    },
    "plugins": [
      "expo-asset",
      "expo-router"
    ]
  }
}
